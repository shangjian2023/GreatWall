__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.env
.coverage

_wheels/
*.whl

# Local docs and extracted archives (not tracked)
docs/*
!docs/adr/
!docs/findings/
!docs/ARCHITECTURE.md
!docs/COMPETITION.md
!docs/EXPERIMENTS.md
!docs/ROADMAP.md
!docs/DELIVERY.md
_extract/

# Large model files generally ignored, except LoRA adapters under runs/
*.safetensors
*.bin
*.pt
*.pth
!runs/**/adapter_model.safetensors

# Downloaded model checkpoints (tdc2023, etc.)
models/

# Temporary screenshots and test output
dogfood-output/

# Training logs and run artifacts in runs/ are not tracked (only LoRA weights)
runs/*.log
runs/**/*.log
runs/*/inversion_report.json
runs/*/discovered_targets.json
runs/*/stage2.log
runs/**/README.md

# Isolated competition training and detector outputs
competition_runs/

# Keep lightweight JSON reports for demo comparison
!results/**/*.json
